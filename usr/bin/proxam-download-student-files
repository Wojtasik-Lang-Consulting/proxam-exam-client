#!/usr/bin/env python3
"""
proxam-download-student-files
------------------------------
Wird beim Exam-Boot aufgerufen (nach searchExamServer, vor dem Prüfungsbeginn).
Lädt vom ProXam-Backend alle genehmigten Student-Files herunter und legt
sie in /run/initramfs/student-files/ ab, damit sie im Exam-Environment
verfügbar sind.

Endpoints (ProXam-Backend):
  GET /proxam/ticket/student-files/{token}
      → [{ id, filename, size, downloadUrl }]
  GET /proxam/ticket/student-files/{token}/{fileId}
      → Datei-Download

Aufruf:
  proxam-download-student-files          # liest token aus /info
  proxam-download-student-files <token>  # token direkt übergeben
"""

import sys
import os
import subprocess
import json
import requests
import logging
from pathlib import Path

# append to the interpreter's search path for modules
directory = "/var/lib/lernstick-exam-client/persistent/var/lib/lernstick-exam-client"
sys.path.append(directory)
import functions as helpers

INFO_FILE   = '/run/initramfs/info'
DEST_DIR    = Path('/run/initramfs/student-files')
LOG_FILE    = '/var/log/proxam-download-student-files.log'
LOG_LEVEL   = logging.INFO

def get_info(variable):
    cmd = 'set -a; source "{file}"; set +a; printf "%s" "${variable}"'.format(
        file=INFO_FILE, variable=variable)
    try:
        return subprocess.check_output(['bash', '-c', cmd]).decode(sys.stdout.encoding).strip() or None
    except Exception:
        return None

def setup_logging():
    logger = logging.getLogger('proxam-student-files')
    logger.setLevel(LOG_LEVEL)
    fmt = logging.Formatter('%(asctime)s %(levelname)s %(message)s')
    ch = logging.StreamHandler()
    ch.setFormatter(fmt)
    fh = logging.FileHandler(LOG_FILE)
    fh.setFormatter(fmt)
    logger.addHandler(ch)
    logger.addHandler(fh)
    return logger

def build_base_url():
    proto = get_info('serverProto') or 'https'
    host  = get_info('serverHost')
    port  = get_info('serverPort')
    if not host:
        return None
    if port and port not in ('80', '443'):
        return f"{proto}://{host}:{port}"
    return f"{proto}://{host}"

def fetch_file_list(base_url, token, session):
    url = f"{base_url}/proxam/ticket/student-files/{token}"
    try:
        r = session.get(url, timeout=15)
        if r.status_code == 404:
            logger.info("No student files endpoint or no files for this ticket.")
            return []
        if r.status_code != 200:
            logger.warning(f"Student-files list returned HTTP {r.status_code}. Skipping.")
            return []
        return r.json()
    except Exception as e:
        logger.warning(f"Could not fetch student-files list: {e}. Skipping.")
        return []

def download_file(base_url, token, file_id, filename, dest_dir, session):
    url = f"{base_url}/proxam/ticket/student-files/{token}/{file_id}"
    dest = dest_dir / filename
    try:
        with session.get(url, stream=True, timeout=60) as r:
            if r.status_code != 200:
                logger.error(f"Failed to download {filename}: HTTP {r.status_code}")
                return False
            with open(dest, 'wb') as f:
                for chunk in r.iter_content(chunk_size=65536):
                    f.write(chunk)
        logger.info(f"Downloaded: {filename} → {dest}")
        return True
    except Exception as e:
        logger.error(f"Error downloading {filename}: {e}")
        return False

if __name__ == '__main__':
    logger = setup_logging()
    logger.info('proxam-download-student-files started')

    # Token: from command line arg or /info file
    if len(sys.argv) >= 2:
        token = sys.argv[1]
    else:
        token = get_info('token')

    if not token:
        logger.warning("No token found. Skipping student-file download.")
        sys.exit(0)

    base_url = build_base_url()
    if not base_url:
        logger.warning("Could not determine server URL from /info. Skipping.")
        sys.exit(0)

    DEST_DIR.mkdir(parents=True, exist_ok=True)
    # chown to user (uid 1000) so files are accessible in exam session
    os.chown(DEST_DIR, 1000, 1000)

    session = requests.Session()
    session.mount('http://',  requests.adapters.HTTPAdapter(max_retries=2))
    session.mount('https://', requests.adapters.HTTPAdapter(max_retries=2))

    files = fetch_file_list(base_url, token, session)
    if not files:
        logger.info("No approved student files to download.")
        sys.exit(0)

    logger.info(f"Found {len(files)} approved student file(s). Downloading...")
    ok, fail = 0, 0
    for f in files:
        file_id  = f.get('id')
        filename = f.get('filename') or f.get('originalName', f'file_{file_id}')
        # Sanitize filename — no path traversal
        filename = Path(filename).name
        if not filename:
            continue
        if download_file(base_url, token, file_id, filename, DEST_DIR, session):
            ok += 1
        else:
            fail += 1

    logger.info(f"Student-file download complete: {ok} ok, {fail} failed.")
    if fail > 0:
        sys.exit(1)
    sys.exit(0)
